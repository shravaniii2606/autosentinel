# Google Earth Engine service-account auth for headless deploys.
# Create a service account JSON key in the `ee-autosentinel` GCP project,
# then paste the complete JSON key as one single-line env var value.
# Keep the private_key newline escapes as \n and never commit real key material.
GEE_SERVICE_ACCOUNT_EMAIL=autosentinel-gee@ee-autosentinel.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"ee-autosentinel","private_key_id":"REPLACE_ME","private_key":"-----BEGIN PRIVATE KEY-----\\nREPLACE_ME\\n-----END PRIVATE KEY-----\\n","client_email":"autosentinel-gee@ee-autosentinel.iam.gserviceaccount.com","client_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"REPLACE_ME","universe_domain":"googleapis.com"}
